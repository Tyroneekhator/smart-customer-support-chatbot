# Backend settings
# Local SQLite example:
DATABASE_URL=sqlite:///./chatbot.db

# PostgreSQL deployment example:
# DATABASE_URL=postgresql://cookiebot_user:cookiebot_password@localhost:5432/cookiebot_db

# Comma-separated frontend URLs allowed to call the backend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Default local admin account created when the database has no admins yet
ADMIN_USERNAME=admin
ADMIN_EMAIL=ekhatortyrone98@gmail.com
ADMIN_PASSWORD=1nf1n1x098@

# Change this before deploying the project.
# Use a long random value, not the example below.
ADMIN_SECRET_KEY=tyrone-is-a-programmer
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=120

# Optional PostgreSQL connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
